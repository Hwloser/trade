{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Homebrew)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PREFIX_PATH": "/opt/homebrew",
        "BUILD_TESTING": "ON",
        "BUILD_PYTHON_BINDINGS": "OFF"
      }
    },
    {
      "name": "debug",
      "inherits": "default",
      "displayName": "Debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "python",
      "inherits": "default",
      "displayName": "With Python bindings",
      "cacheVariables": {
        "BUILD_PYTHON_BINDINGS": "ON"
      }
    },
    {
      "name": "linux",
      "displayName": "Linux (system packages)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "BUILD_PYTHON_BINDINGS": "OFF"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "linux",
      "displayName": "Linux Debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-python",
      "inherits": "linux",
      "displayName": "Linux with Python bindings",
      "cacheVariables": {
        "BUILD_PYTHON_BINDINGS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux",
      "configurePreset": "linux",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
